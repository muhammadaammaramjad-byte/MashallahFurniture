{
  "name": "mashallah-furniture",
  "version": "1.0.0",
  "description": "Modern furniture e-commerce website",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext js,jsx",
    "lint:fix": "eslint src --ext js,jsx --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "type-check": "tsc --noEmit",
    "analyze": "vite bundle-visualizer",
    "deploy:netlify": "npm run build && netlify deploy --prod",
    "deploy:vercel": "vercel --prod",
    "deploy:github": "gh-pages -d dist",
    "predeploy": "npm run test && npm run build",
    "health": "node scripts/health-check.js",
    "preview:prod": "npm run build && npm run preview"
  },
  "devDependencies": {
    "@testing-library/dom": "^9.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "vitest": "^1.0.0",
    "jsdom": "^23.0.0",
    "eslint-plugin-jsx-a11y": "^6.7.0",
    "eslint-plugin-jest": "^27.0.0",
    "vite-plugin-bundle-visualizer": "^1.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.6.1",
    "prettier": "^3.0.0",
    "vite": "^4.4.0"
  },
  "dependencies": {
    "vite": "^5.0.0",
    "@emailjs/browser": "^3.11.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ]
}